    "typecheck": "tsc --noEmit",
    "openapi:generate": "bun run src/openapi.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/swagger": "^1.3.1",
    "elysia": "^1.4.28"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "typescript": "^6.0.3"
  }
}
